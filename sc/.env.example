# HemaChain — Sepolia deploy + verificación (Phase 8)
#
# Copiá este archivo a  sc/.env  (gitignored) y completá los tres valores.
# Foundry carga sc/.env automáticamente al correr `forge script` desde sc/.
# Cómo obtener cada valor → docs/PENDIENTES-USUARIO.md
#
# NUNCA commitees el sc/.env real (sólo este .example sin valores).

# RPC de Sepolia (Alchemy / Infura, plan gratuito → copiar la URL HTTPS)
SEPOLIA_RPC_URL=

# Clave privada de una wallet DEDICADA al deploy (no tu wallet personal).
# Necesita algo de Sepolia ETH de un faucet para pagar el gas.
DEPLOYER_PRIVATE_KEY=

# API key de Etherscan para verificar el código fuente de los contratos
ETHERSCAN_API_KEY=

# ── Deploy + verificación (un comando, desde sc/) ──────────────────────
#   cp .env.example .env   # y completar arriba
#   forge script script/Deploy.s.sol \
#     --rpc-url sepolia \
#     --private-key "$DEPLOYER_PRIVATE_KEY" \
#     --broadcast --verify
#
# Las direcciones desplegadas quedan en broadcast/Deploy.s.sol/11155111/ —
# se copian al README §6 y al web/.env.local (NEXT_PUBLIC_*_ADDRESS_SEPOLIA).
