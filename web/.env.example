# --- Chain selection ---------------------------------------------------
# Which chain the frontend talks to by default. 31337 = Anvil, 11155111 = Sepolia.
NEXT_PUBLIC_CHAIN_ID=31337

# Optional override for the Sepolia RPC URL. Default is a free public node.
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<your-key>

# --- Contract addresses ------------------------------------------------
# For Anvil, leaving these empty falls back to the deterministic addresses
# produced by Deploy.s.sol from the first Anvil account at nonces 0/1/2.
# Override only if you redeploy in a non-trivial order.
# NEXT_PUBLIC_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# NEXT_PUBLIC_TRACEABILITY_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
# NEXT_PUBLIC_CERTIFICATE_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# Sepolia — populated in Phase 8 after the first verified deployment.
# NEXT_PUBLIC_REGISTRY_ADDRESS_SEPOLIA=
# NEXT_PUBLIC_TRACEABILITY_ADDRESS_SEPOLIA=
# NEXT_PUBLIC_CERTIFICATE_ADDRESS_SEPOLIA=

# --- IPFS (Phase 5) ----------------------------------------------------
# Used by the certificate upload route. Keep the JWT server-side only.
# PINATA_JWT=

# --- AI (Phase 7) ------------------------------------------------------
# Used by the "Ask HemaChain" floating agent.
# ANTHROPIC_API_KEY=
